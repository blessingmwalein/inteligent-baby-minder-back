# ====== Required ======

# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# JWT signing secret (min 16 chars). Generate with: openssl rand -base64 48
JWT_SECRET="change-me-min-16-chars-please-use-a-real-secret"

# Google Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ====== Optional ======

# Node environment
NODE_ENV="development"

# Server port
PORT=5000

# JWT token lifetime (any ms/zeit string)
JWT_EXPIRES_IN="7d"

# Gemini model name. Common free-tier choices:
#   gemini-2.5-flash         (recommended — stable, fast, generous quota)
#   gemini-2.5-flash         (newer, slightly better reasoning)
#   gemini-flash-latest      (always points to the latest flash model)
# Avoid gemini-1.5-flash — it was removed from the public v1beta API in early 2026.
GEMINI_MODEL="gemini-2.5-flash"

# Log level: error | warn | log | debug | verbose
LOG_LEVEL="log"

# Set to "true" to log raw chat prompts/replies (PII risk — debug only)
LOG_PROMPT_CONTENTS="false"

# Per-message size and rate limits
CHAT_MAX_MESSAGE_LENGTH=4000
CHAT_RATE_LIMIT_PER_MIN=20
GLOBAL_RATE_LIMIT_PER_MIN=60
